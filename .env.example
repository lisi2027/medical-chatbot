# 阿里云百炼 API Key - 必填
DASHSCOPE_API_KEY=your_api_key_here

# 阿里云百炼 API 地址 - 默认即可
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 后端服务端口
BACKEND_PORT=6066

# Streamlit 前端端口
STREAMLIT_PORT=8501

# 向量模型路径
VECTOR_MODEL_PATH=./bge-large-zh-v1.5

# 医疗数据目录
MEDICAL_DATA_DIR=./Data

# 是否启用 RAG 检索增强
USE_RAG=true

# RAG 检索返回数量
RAG_TOP_K=3

# RAG 相似度阈值
RAG_THRESHOLD=0.5